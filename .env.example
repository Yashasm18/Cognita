# Cognita 🧠 Environment Variables
# Copy to .env and fill in your values

# ═══════════════════════════════════════════════════
# LLM (pick one — Groq is recommended for speed)
# ═══════════════════════════════════════════════════

# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# Ollama fallback (if Groq is unavailable)
# Install Ollama: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# "groq" or "ollama"
LLM_PROVIDER=groq

# ═══════════════════════════════════════════════════
# Supabase (optional — for persistent storage)
# ═══════════════════════════════════════════════════

# Get these from https://supabase.com/dashboard
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ═══════════════════════════════════════════════════
# Voice
# ═══════════════════════════════════════════════════

# Whisper STT model: tiny, base, small, medium, large
WHISPER_MODEL=base

# TTS engine: "gtts" (free, online) or "piper" (offline, fast)
TTS_ENGINE=gtts
PIPER_MODEL_PATH=

# ═══════════════════════════════════════════════════
# Server
# ═══════════════════════════════════════════════════

HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
